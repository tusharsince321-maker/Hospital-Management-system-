# Database
MONGO_URI=mongodb://localhost:27017/hospital_management
USE_IN_MEMORY_MONGO=false

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key
JWT_EXPIRES=7d
COOKIE_EXPIRE=7

# One-time Admin Bootstrap (optional)
BOOTSTRAP_ADMIN_KEY=change-me-and-keep-secret

# Startup Admin Sync (optional recovery for deployments)
SYNC_ADMIN_ON_STARTUP=false
SYNC_ADMIN_PASSWORD=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=User
ADMIN_PHONE=01234567890
ADMIN_NIC=1234567890123
ADMIN_DOB=1990-01-01
ADMIN_GENDER=Male

# Server
PORT=4000
NODE_ENV=development

# Frontend URLs
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# Cloudinary (doctor avatars)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
